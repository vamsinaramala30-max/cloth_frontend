# Frontend Environment Configuration
# Copy this file to .env.local and update values for your environment

# Backend API URL
# Must match the backend server URL (protocol://host:port/api)
NEXT_PUBLIC_API_URL=http://localhost:5001/api

# Environment mode (development, production, or test)
NEXT_PUBLIC_NODE_ENV=development

# Optional: Override for production deployments
# NEXT_PUBLIC_API_URL=https://api.rare-rabbit.com/api
# NEXT_PUBLIC_NODE_ENV=production
